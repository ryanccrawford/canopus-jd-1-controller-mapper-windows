<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CanopusMapApp.DeviceDiagnosticsWindow"
        Title="JD-1 Device Diagnostics"
        Height="720"
        Width="860"
        Background="#151515"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#212121" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Connected Device" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="ConnectionText" Text="No JD-1 connected" Foreground="#f0ad4e" Margin="0,8,0,4"/>
                <TextBlock x:Name="DeviceSummaryText" Text="Open this window, then plug in the controller or wait for detection." Foreground="#d0d0d0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#212121" CornerRadius="6" Padding="12" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Device Details" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBox x:Name="DeviceDetailsText" Margin="0,8,0,0" IsReadOnly="True" Height="150" TextWrapping="Wrap" AcceptsReturn="True" ScrollViewer.VerticalScrollBarVisibility="Auto" Background="#101010" Foreground="#d0d0d0" BorderThickness="0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#212121" CornerRadius="6" Padding="12">
                <StackPanel>
                    <TextBlock Text="Manual Output Report" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Enter hex bytes. Example: 01 07 or 00 01 07. The app now tries both output and feature report paths automatically." Foreground="#bbbbbb" FontSize="12" Margin="0,6,0,8" TextWrapping="Wrap"/>
                    <TextBox x:Name="ManualReportText" Text="01 07" Background="#101010" Foreground="White" BorderThickness="0" Padding="8"/>
                    <Button Content="Send Report" Click="SendReport_Click" Margin="0,10,0,0" Height="34" Background="DodgerBlue" Foreground="White" FontWeight="Bold"/>
                    <Button Content="Probe Feature IDs" Click="ProbeFeatureIds_Click" Margin="0,8,0,0" Height="34" Background="#555555" Foreground="White" FontWeight="Bold"/>
                    <TextBlock x:Name="SendStatusText" Margin="0,10,0,0" Foreground="#bbbbbb" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#212121" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Input Reports" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <Button DockPanel.Dock="Top" Content="Clear Input Log" Click="ClearInputLog_Click" Width="120" Height="28" Margin="0,8,0,8" HorizontalAlignment="Left" Background="#3a3a3a" Foreground="White"/>
                <TextBox x:Name="InputLogText" IsReadOnly="True" AcceptsReturn="True" ScrollViewer.VerticalScrollBarVisibility="Auto" Background="#101010" Foreground="#d0d0d0" BorderThickness="0" TextWrapping="NoWrap"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#212121" CornerRadius="6" Padding="12" Margin="0,0,10,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Output Reports" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <Button DockPanel.Dock="Top" Content="Clear Output Log" Click="ClearOutputLog_Click" Width="130" Height="28" Margin="0,8,0,8" HorizontalAlignment="Left" Background="#3a3a3a" Foreground="White"/>
                <TextBox x:Name="OutputLogText" IsReadOnly="True" AcceptsReturn="True" ScrollViewer.VerticalScrollBarVisibility="Auto" Background="#101010" Foreground="#d0d0d0" BorderThickness="0" TextWrapping="NoWrap"/>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="#212121" CornerRadius="6" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Feature Reports" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <Button DockPanel.Dock="Top" Content="Clear Feature Log" Click="ClearFeatureLog_Click" Width="130" Height="28" Margin="0,8,0,8" HorizontalAlignment="Left" Background="#3a3a3a" Foreground="White"/>
                <TextBox x:Name="FeatureLogText" IsReadOnly="True" AcceptsReturn="True" ScrollViewer.VerticalScrollBarVisibility="Auto" Background="#101010" Foreground="#d0d0d0" BorderThickness="0" TextWrapping="NoWrap"/>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Background="#212121" CornerRadius="6" Padding="12" Margin="10,0,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Feature Successes" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <Button DockPanel.Dock="Top" Content="Clear Success Log" Click="ClearFeatureSuccessLog_Click" Width="140" Height="28" Margin="0,8,0,8" HorizontalAlignment="Left" Background="#3a3a3a" Foreground="White"/>
                <TextBox x:Name="FeatureSuccessLogText" IsReadOnly="True" AcceptsReturn="True" ScrollViewer.VerticalScrollBarVisibility="Auto" Background="#101010" Foreground="#9fe89f" BorderThickness="0" TextWrapping="NoWrap"/>
            </DockPanel>
        </Border>
        </Grid>
    </Grid>
</Window>
