<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CanopusMapApp.MainWindow"
        Title="Canopus JD-1 Pro Mapper" Height="800" Width="720" Background="#1e1e1e"
        Icon="avares://canopusMapApp/trayIcon.ico"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="CANOPUS JD-1 PRO MAPPER" FontSize="22" Foreground="White" FontWeight="Bold"/>
            <TextBlock x:Name="StatusText" Text="Status: Initializing..." Foreground="Orange" FontSize="14"/>
            <TextBlock x:Name="LedDebugText" Text="LED: 0x07 (DECK=True, JOG=True, SHUTTLE=True)" Foreground="LightGray" FontSize="12" Margin="0,4,0,0"/>
            <TextBlock Text="App will stay active in System Tray when closed." Foreground="Gray" FontSize="10" Margin="0,5,0,0"/>
        </StackPanel>

        <TabControl x:Name="DeviceTabs" Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="Background" Value="#2d2d2d"/>
                    <Setter Property="Foreground" Value="Gray"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="15,8"/>
                    <Setter Property="Margin" Value="0,0,5,0"/>
                    <Style Selector="^ /template/ Border#Border">
                        <Setter Property="Background" Value="{Binding $parent[TabItem].Background}"/>
                        <Setter Property="CornerRadius" Value="4,4,0,0"/>
                        <Setter Property="Padding" Value="{Binding $parent[TabItem].Padding}"/>
                    </Style>
                    <Style Selector="^:selected">
                        <Setter Property="Background" Value="#3a3a3a"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                </Style>
            </TabControl.Styles>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Device Diagnostics" Click="OpenDiagnostics_Click" Width="170" Height="35" Margin="0,0,10,0" Background="#3a3a3a" Foreground="White" FontWeight="Bold"/>
            <Button Content="Save Mapping" Click="SaveConfig_Click" Width="150" Height="35" Background="DodgerBlue" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
