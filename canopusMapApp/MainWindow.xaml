<Window x:Class="CanopusMapApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Canopus JD-1 Pro Mapper" Height="800" Width="600" Background="#1e1e1e"
        Icon="trayIcon.ico"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="CANOPUS JD-1 PRO MAPPER" FontSize="22" Foreground="White" FontWeight="Bold"/>
            <TextBlock x:Name="StatusText" Text="Status: Initializing..." Foreground="Orange" FontSize="14"/>
            <TextBlock Text="App will stay active in System Tray when closed." Foreground="Gray" FontSize="10" Margin="0,5,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="MappingList">
                <Grid Margin="10,0,10,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Bit ID" Foreground="Gray" FontSize="10"/>
                    <TextBlock Grid.Column="1" Text="Physical Label" Foreground="Gray" FontSize="10"/>
                    <TextBlock Grid.Column="2" Text="Keyboard Key" Foreground="Gray" FontSize="10"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Save Mapping" Click="SaveConfig_Click" Width="150" Height="35" Background="DodgerBlue" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>